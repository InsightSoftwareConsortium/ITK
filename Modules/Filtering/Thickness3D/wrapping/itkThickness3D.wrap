itk_wrap_class("itk::MedialThicknessImageFilter3D" POINTER)
unique(wrap_input_image_types "${WRAP_ITK_SCALAR};UC")
unique(wrap_output_image_types "${WRAP_ITK_REAL}")
foreach(in ${wrap_input_image_types})
  foreach(out ${wrap_output_image_types})
    itk_wrap_image_filter_combinations("${in}" "${out}" 3)
  endforeach()
endforeach()
itk_end_wrap_class()
